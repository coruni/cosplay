# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cosplay

# ──────────────────────────────────────────────
# Redis (caching & view counters)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Admin auth token
# ──────────────────────────────────────────────
ADMIN_TOKEN=your-secret-admin-token

# ──────────────────────────────────────────────
# S3-compatible object storage
# (AWS S3 / Cloudflare R2 / MinIO all work)
# ──────────────────────────────────────────────

# Server-side credentials (secret) — used to generate presigned upload URLs
S3_BUCKET=
S3_REGION=auto
# Endpoint for R2/MinIO, e.g. https://<account>.r2.cloudflarestorage.com
# Leave EMPTY for AWS S3 (uses default AWS endpoint).
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Public base URL for serving images (client-safe).
# The stored DB value is the S3 key; this URL is prefixed at render time.
#   R2 custom domain : https://cdn.example.com
#   R2 dev public URL: https://pub-xxxxx.r2.dev
#   AWS S3           : https://bucket.s3.region.amazonaws.com  (or CloudFront domain)
#   MinIO            : https://minio.example.com/bucket
NEXT_PUBLIC_S3_PUBLIC_URL=

# ─────────────────────────────────────────────
# Generic external image host (Chevereto-compatible API)
# ─────────────────────────────────────────────
# Works with ANY Chevereto-based host (e.g. pic.moebox.io) — nothing is
# hard-coded. When selected as the upload backend in the admin gallery editor,
# images are proxied through /admin/api/upload-imagehost (the key stays
# server-side) and stored as their public hosted URL. NSFW galleries upload
# with nsfw=1.
#
#   IMAGE_HOST_API_URL  — full upload URL, e.g. https://pic.moebox.io/api/1/upload
#                         (a bare origin like https://host.com is also accepted;
#                          the default /api/1/upload path is then appended)
#   IMAGE_HOST_API_KEY  — API key from the host's settings / API page
#   IMAGE_HOST_NAME     — optional display name shown in the admin UI
IMAGE_HOST_API_URL=
IMAGE_HOST_API_KEY=
IMAGE_HOST_NAME=

# ─────────────────────────────────────────────
# Subscription / membership
# ─────────────────────────────────────────────
# Monthly price (CNY) charged per 30-day cycle
SUBSCRIPTION_PRICE=30
# Monthly quota: combined unlock + download units per cycle
SUBSCRIPTION_QUOTA=120
# Quota reset cycle length in days (rolling from subscribe date)
SUBSCRIPTION_CYCLE_DAYS=30
